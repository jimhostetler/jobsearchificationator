generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum JobStatus {
  viewed
  applied
  interviewed
  rejected
  cancelled
}

model Job {
  id             String    @id @default(uuid())
  title          String
  company        String
  rawDescription String
  salary         String?
  location       String?
  remote         Boolean   @default(false)

  matchScore     Int
  matchReasons   String    // JSON array stored as string
  concerns       String    // JSON array stored as string

  status         JobStatus @default(viewed)

  contacts       Contact[]

  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
}

model Contact {
  id          String   @id @default(uuid())
  name        String
  role        String?
  linkedIn    String?
  reachedOut  Boolean  @default(false)

  job         Job      @relation(fields: [jobId], references: [id], onDelete: Cascade)
  jobId       String

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
